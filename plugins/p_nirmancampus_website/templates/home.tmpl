{{ if .HasPopup }}
  <div class="popup-overlay" id="latestInfoPopup">
    <div class="popup-content">
      <img src="{{ .PopupImageURL }}" alt="Latest Information">
      <button class="close-btn" onclick="closePopup()">Close</button>
    </div>
  </div>

  <script>
    window.onload = function() {
      document.getElementById('latestInfoPopup').style.display = 'flex';
    };

    function closePopup() {
      document.getElementById('latestInfoPopup').style.display = 'none';
    }

    document.getElementById('latestInfoPopup').addEventListener('click', function(e) {
      if (e.target === this) {
        closePopup();
      }
    });
  </script>
{{ end }}

