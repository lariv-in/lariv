{{ template "header.tmpl" . }}

<section 
  class="relative h-screen bg-cover bg-center" 
  style="background-image:url('{{ static "images/main2.jpg" }}')"
>
  <!-- dark overlay -->
  <div class="absolute inset-0 bg-black/50"></div>

  <!-- Main hero content -->
  <div class="relative z-6 flex flex-col items-center justify-center h-full text-center px-4">
    <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-4">
      Welcome to Nirman Campus
    </h1>
    <p class="text-lg md:text-2xl text-gray-200 mb-8">
      Empowering Education, Inspiring Futures
    </p>
    <a 
      href="/about-us/" 
      class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition"
    >
      Learn More
    </a>
    <a
      href="https://wa.me/919478450740"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat on WhatsApp for Admissions"
      class="inline-flex items-center bg-[#25D366] hover:bg-[#20AB53] text-white font-semibold py-3 px-8 rounded-lg transition duration-150 ease-in-out"
    >
      <i class="fab fa-whatsapp fa-lg"></i> <span class="ml-2">Admission Line</span>
    </a>
  </div>
</section>

<section class="bg-gray-50 py-12 border-t border-gray-200" aria-labelledby="announcements-heading">
  <div class="container mx-auto px-4">
    <h2 id="announcements-heading" class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-8">
      Announcements
    </h2>
    <div class="max-h-80 md:max-h-96 overflow-y-auto overscroll-y-contain pr-2 [scrollbar-gutter:stable]">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 pb-1">
      {{ range .Announcements }}
        <article class="bg-white rounded-xl shadow-md border border-gray-100 p-5 flex items-start gap-3 hover:shadow-lg transition-shadow">
          <img src="{{ static "images/new_icon.gif" }}" alt="" class="h-5 w-5 mt-0.5 flex-shrink-0" aria-hidden="true"/>
          <p class="text-gray-800 text-sm md:text-base leading-relaxed">{{ .Text }}</p>
        </article>
      {{ else }}
        <div class="col-span-full">
          <div class="bg-white rounded-xl shadow-md border border-gray-100 p-8 text-center text-gray-500 max-w-xl mx-auto">
            No announcements right now.
          </div>
        </div>
      {{ end }}
      </div>
    </div>
  </div>
</section>

<section id="hero" class="pt-8">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center md:items-start gap-8 justify-center">
      
      <!-- Image on the left -->
      <div class="w-full md:w-1/4">
        <img
          src="{{ static "images/main2.jpg" }}"
          alt="Nirman Campus"
          class="w-full h-64 md:h-auto object-cover rounded-lg shadow-lg"
        />
      </div>

      <!-- Content on the right -->
      <div class="w-full md:w-1/2 flex flex-col justify-center space-y-4">
        <h2 class="text-2xl md:text-3xl font-semibold">
          NIRMAN CAMPUS OF EDUCATION, RESEARCH AND TRAINING, <br>SUNAM UDHAM SINGHWALA (PUNJAB)
        </h2>
        <p class="text-justify">
          Nirman Campus of Education, Research and Training is a non-profit joint venture of Kansal Foundation and NASO,
          initiated by its visionary founder Dr. Amit Kansal. The institute is committed to providing accessible,
          high-quality education through both regular and distance learning modes.
        </p>
        <p class="text-justify">
          We’re proudly affiliated with Indira Gandhi National Open University (IGNOU), a central university under the
          Ministry of Education, and Maharaja Ranjit Singh Punjab Technical University (MRSPTU), Bathinda, a leading
          state technical university.
        </p>
        <p class="text-justify">
          At Nirman Campus, we offer a wide range of undergraduate, postgraduate, diploma, and certification programs.
          Our experienced faculty and supportive academic environment empower students to succeed in their chosen careers.
          Whether you’re a working professional or a full-time learner, we provide the right platform for your academic goals
          and lifelong learning.
        </p>

        <!-- Prospectus Buttons -->
        <div class="flex flex-wrap gap-4 mt-4">
          <a
            href="{{ static "downloads/brochure.pdf" }}"
            class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700"
          >
            Download NCERT Prospectus
          </a>
          <a
            href="https://www.ignou.ac.in/viewFile/hq/common/Common-Prospectus-English.pdf"
            target="_blank"
            class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700"
          >
            Download IGNOU Prospectus
          </a>
          
          <a
            href="{{ static "downloads/ADMISSION APPLICATION FORM.pdf" }}"
            target="_blank"
            class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700"
          >
            Admission Form (MRSPTU)
          </a>
          
        </div>

        <!-- Feedback & social -->
        <div class="mt-6 flex flex-col sm:flex-row sm:items-center sm:justify-start gap-4">
          <a
            href="/feedback-form/"
            class="inline-block bg-blue-600 text-white font-semibold py-3 px-6 rounded-lg hover:bg-blue-700"
          >
            Give Your Feedback!
          </a>
          <div class="flex space-x-4">
            <a href="https://whatsapp.com/channel/0029Vaj8AM0F6sn7LHwyQE0D" target="_blank">
              <img src="{{ static "images/wa.png" }}" alt="WhatsApp" class="h-10 w-10 rounded" />
            </a>
            <a href="https://t.me/nirmancampus" target="_blank">
              <img src="{{ static "images/tele.png" }}" alt="Telegram" class="h-10 w-10 rounded" />
            </a>
            <a href="https://www.youtube.com/channel/UC3ZaEEWH9hsCDM7alcIEvDA" target="_blank">
              <img src="{{ static "images/yt.png" }}" alt="YouTube" class="h-10 w-10 rounded" />
            </a>
            <a href="https://www.facebook.com/nirmancampus.sunam/" target="_blank">
              <img src="{{ static "images/fb.png" }}" alt="Facebook" class="h-10 w-10 rounded" />
            </a>
            <a href="https://www.instagram.com/nirmancampussunam/" target="_blank">
              <img src="{{ static "images/ig.svg" }}" alt="Instagram" class="h-10 w-10 rounded" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<section id="founder-note" class="pt-12">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center md:items-start gap-8 justify-center">

      <!-- Content on the left -->
      <div class="w-full md:w-1/2 flex flex-col justify-center space-y-4">
        <h2 class="text-2xl md:text-3xl font-semibold">
          A Note from the Founder
        </h2>
        <p class="text-justify">
          Welcome to Nirman Campus! Your journey here contributes directly to our vision of <strong>Vikasit Bharat</strong>—a thriving, self-reliant nation built on the foundations of quality education and innovation.
        </p>
        <p class="text-justify">
          We believe in <strong>Youth Empowerment</strong>. You are the catalysts for change, and your talents and initiatives will shape communities, bridge gaps, and inspire others to join this transformative mission.
        </p>
        <p class="text-justify">
          True <strong>Nationalism</strong> is active service: uplifting those around you, upholding the values of integrity and unity, and dedicating your skills to the progress of our country.
        </p>
        <p class="mt-4 font-semibold">
          Dr. Amit Kansal<br/>
          Founder, Nirman Campus &amp; Kansal Foundation
        </p>
      </div>

      <!-- Founder’s photo on the right -->
      <div class="w-full md:w-1/5">
        <img
          src="{{ static "images/drkansal.jpeg" }}"
          alt="Dr. Amit Kansal"
          class="w-full h-64 md:h-auto object-cover rounded-lg shadow-lg"
        />
      </div>

    </div>
  </div>
</section>

