<div class="relative bg-cover bg-center bg-fixed" style="background-image:url('{{ static "images/hero.jpg" }}')">
  <div class="absolute inset-0 bg-black/50"></div>
  <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4 py-16">
    <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-4">Nirman Campus</h1>
    <p class="text-lg md:text-2xl text-gray-200 mb-8">Empowering Education, Inspiring Futures</p>
  </div>
</div>

<section class="py-12 px-4 bg-primary/10 border-y border-primary/20">
  <div class="max-w-6xl mx-auto">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary text-center mb-2">Credibility &amp; recognition</p>
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-4">Their excellence becomes your qualification</h2>
    <p class="text-center max-w-3xl mx-auto text-base-content/90 leading-relaxed mb-8">
      <strong>Nirman Campus is IGNOU Study Center 2299</strong> and works in affiliation with <strong>MRSPTU</strong>. We are not a standalone label—when you study here, <strong>you inherit the stature of two of India's most trusted universities</strong>: national recognition, statutory backing, and reputations built over decades.
    </p>
    <div class="max-w-4xl mx-auto mb-10 rounded-2xl border-2 border-primary bg-base-100 shadow-xl overflow-hidden">
      <div class="bg-primary text-primary-content px-4 py-2.5 text-center text-xs sm:text-sm font-bold uppercase tracking-widest">
        National Institutional Ranking Framework (NIRF)
      </div>
      <div class="px-5 py-8 sm:px-10 sm:py-10 text-center">
        <p class="text-4xl font-black text-primary leading-none mb-2">NIRF #1 Rank</p>
        <p class="text-lg sm:text-xl font-semibold text-base-content/80 mb-6">Open University category — Government of India</p>
        <p class="text-base sm:text-lg text-base-content/90 leading-relaxed max-w-2xl mx-auto text-left sm:text-center">
          IGNOU is a Central University run by the Government of India. It has NIRF #1 Rank, is recognised by UGC and is the Largest Open University in India.
        </p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="card bg-base-100 shadow-md border border-primary/10 text-left">
        <div class="card-body">
          <h3 class="card-title text-lg">What we deliver through IGNOU</h3>
          <p class="text-base-content/90 leading-relaxed">
            From this study centre, <strong>we offer you the same programmes that flow from that NIRF #1-ranked open university</strong>—the credentials summarised above. <strong>Your degree carries weight</strong>: qualifications earned through us are valid in India and abroad, with the approvals that matter—UGC, DEB, AIU, AICTE, and the Ministry of Education, Government of India.
          </p>
        </div>
      </div>
      <div class="card bg-base-100 shadow-md border border-primary/10 text-left">
        <div class="card-body">
          <h3 class="card-title text-lg">What we unlock with MRSPTU</h3>
          <p class="text-base-content/90 leading-relaxed">
            Our affiliation with <strong>Maharaja Ranjit Singh Punjab Technical University (MRSPTU), Bathinda</strong>—established under Punjab Act No. 5 of 2015—<strong>anchors your technical and professional pathway in a statutory technical university</strong> built for innovation and industry readiness. <strong>You benefit from the same mission</strong>: rigorous scientific and professional training designed so graduates are prepared for real workplaces, not just examinations.
          </p>
        </div>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row flex-wrap items-center justify-center gap-3">
      <span class="badge badge-primary badge-lg whitespace-normal h-auto min-h-8 py-2 px-4 text-center leading-snug">IGNOU Study Center - 2299</span>
      <span class="badge badge-neutral badge-lg h-auto min-h-8 py-2 px-4 text-center">MRSPTU affiliated institution</span>
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mt-10 text-center">
      <p class="text-base-content/80 max-w-md sm:mr-2 sm:text-left">See programmes you can pursue through our IGNOU and MRSPTU pathways.</p>
      <a href="/courses-offered/" class="btn btn-primary btn-lg shrink-0">View courses offered</a>
    </div>
  </div>
</section>

{{ if .Announcements }}
<section class="py-16 px-4 bg-base-200">
  <h2 class="text-3xl font-bold text-center mb-10">Announcements</h2>
  <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {{ range .Announcements }}
    <div class="card bg-base-100 shadow-md">
      <div class="card-body">
        <h3 class="card-title">{{ .Title }}</h3>
        {{ if .Description }}<div class="prose">{{ .Description }}</div>{{ end }}
        <div class="text-sm opacity-60 mt-2">{{ .Date }}</div>
      </div>
    </div>
    {{ end }}
  </div>
</section>
{{ end }}

<section class="py-16 px-4 bg-base-100">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
    <div class="card bg-base-200 shadow-md">
      <div class="card-body">
        <h2 class="card-title text-2xl">Contact Us</h2>
        <p>Nirman Campus is dedicated to empowering students through quality education and holistic development.</p>
        <div class="card-actions justify-end mt-4">
          <a href="/contact-us/" class="btn btn-primary">Read More</a>
        </div>
      </div>
    </div>
    <div class="card bg-base-200 shadow-md">
      <div class="card-body">
        <h2 class="card-title text-2xl">Director's Corner</h2>
        <p class="text-sm opacity-70 -mt-1 mb-4">A note from the Founder</p>
        <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
          <div class="w-full md:flex-1 flex flex-col gap-3 text-justify">
            <p>
              Welcome to Nirman Campus! Your journey here contributes directly to our vision of <strong>Vikasit Bharat</strong>—a thriving, self-reliant nation built on the foundations of quality education and innovation.
            </p>
            <p>
              We believe in <strong>Youth Empowerment</strong>. You are the catalysts for change, and your talents and initiatives will shape communities, bridge gaps, and inspire others to join this transformative mission.
            </p>
            <p>
              True <strong>Nationalism</strong> is active service: uplifting those around you, upholding the values of integrity and unity, and dedicating your skills to the progress of our country.
            </p>
            <p class="mt-2 font-semibold not-italic text-left">
              Dr. Amit Kansal<br/>
              Founder, Nirman Campus &amp; Kansal Foundation
            </p>
          </div>
        </div>
        <div class="card-actions justify-end mt-4">
          <a href="https://amitkansal.in" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Read More</a>
        </div>
      </div>
    </div>
  </div>
</section>
