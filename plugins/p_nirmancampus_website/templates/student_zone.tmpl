<section class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-4xl font-bold text-center mb-10">Student Zone</h1>
    {{ if .Announcements }}
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-center mb-10">Announcements</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
        {{ range .Announcements }}
        {{ if .URL }}
        <a href="{{ .URL }}" target="_blank" rel="noopener noreferrer" class="card bg-base-200 border border-base-300 hover:border-primary hover:shadow-lg transition-all cursor-pointer no-underline text-inherit">
          <div class="card-body">
            <h3 class="card-title">{{ .Title }}</h3>
            {{ if .Description }}<div class="prose max-w-none [&_a]:text-blue-600 [&_a]:underline [&_a:hover]:text-blue-800 dark:[&_a]:text-blue-400 dark:[&_a:hover]:text-blue-300">{{ .Description }}</div>{{ end }}
            <div class="text-sm opacity-60 mt-2">{{ .Date }}</div>
          </div>
        </a>
        {{ else }}
        <div class="card bg-base-200 border border-base-300">
          <div class="card-body">
            <h3 class="card-title">{{ .Title }}</h3>
            {{ if .Description }}<div class="prose max-w-none [&_a]:text-blue-600 [&_a]:underline [&_a:hover]:text-blue-800 dark:[&_a]:text-blue-400 dark:[&_a:hover]:text-blue-300">{{ .Description }}</div>{{ end }}
            <div class="text-sm opacity-60 mt-2">{{ .Date }}</div>
          </div>
        </div>
        {{ end }}
        {{ end }}
      </div>
    </div>
    {{ end }}
    {{ if .Sections }}
    <div class="space-y-10">
      {{ range .Sections }}
      <div>
        <h2 class="text-2xl font-semibold mb-4">{{ .Title }}</h2>
        {{ if .Items }}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {{ range .Items }}
          <div class="card bg-base-200 shadow-md">
            <div class="card-body">
              <h3 class="card-title text-lg">{{ .Title }}</h3>
              <div class="card-actions justify-end mt-2">
                <a href="{{ .URL }}" class="btn btn-primary btn-sm">Open</a>
              </div>
            </div>
          </div>
          {{ end }}
        </div>
        {{ else }}
        <p class="opacity-60">No items in this section.</p>
        {{ end }}
      </div>
      {{ end }}
    </div>
    {{ else }}
    <p class="text-center opacity-60">No content available at this time.</p>
    {{ end }}
  </div>
</section>
