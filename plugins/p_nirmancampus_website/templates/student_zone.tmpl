<section class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-4xl font-bold text-center mb-10">Student Zone</h1>
    {{ if .Sections }}
    <div class="space-y-10">
      {{ range .Sections }}
      <div>
        <h2 class="text-2xl font-semibold mb-4">{{ .Title }}</h2>
        {{ if .Items }}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {{ range .Items }}
          <div class="card bg-base-200 shadow-md">
            <div class="card-body">
              <h3 class="card-title text-lg">{{ .Title }}</h3>
              <div class="card-actions justify-end mt-2">
                <a href="{{ .URL }}" class="btn btn-primary btn-sm">Open</a>
              </div>
            </div>
          </div>
          {{ end }}
        </div>
        {{ else }}
        <p class="opacity-60">No items in this section.</p>
        {{ end }}
      </div>
      {{ end }}
    </div>
    {{ else }}
    <p class="text-center opacity-60">No content available at this time.</p>
    {{ end }}
  </div>
</section>
