<section class="py-16 px-4" x-data="{ search: '' }">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-4xl font-bold text-center mb-10">Courses Offered</h1>
    <div class="mb-8 max-w-md mx-auto">
      <input
        type="text"
        x-model="search"
        placeholder="Search courses..."
        class="input input-bordered w-full"
      >
    </div>
    {{ if .Courses }}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {{ range .Courses }}
      <div
        class="card bg-base-200 shadow-md"
        x-show="!search || '{{ .Name }} {{ .Code }} {{ .Level }} {{ .Subject }}'.toLowerCase().includes(search.toLowerCase())"
      >
        <div class="card-body">
          <h2 class="card-title">{{ .Name }}</h2>
          {{ if .Code }}<div class="badge badge-outline">{{ .Code }}</div>{{ end }}
          {{ if .Level }}<div class="text-sm opacity-60">{{ .Level }}</div>{{ end }}
          {{ if .Subject }}<div class="text-sm">{{ .Subject }}</div>{{ end }}
          {{ if .Description }}<p class="mt-2">{{ .Description }}</p>{{ end }}
        </div>
      </div>
      {{ end }}
    </div>
    {{ else }}
    <p class="text-center opacity-60">No courses available at this time.</p>
    {{ end }}
  </div>
</section>
