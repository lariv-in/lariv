{{ template "header.tmpl" . }}

<main class="bg-gray-50 min-h-screen py-12">
  <section class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900">Courses Offered</h1>
      <p class="mt-3 text-gray-600">
        Explore the active courses currently available through Nirman Campus.
      </p>

      <form method="get" action="/courses-offered/" class="mt-8 max-w-md mx-auto flex flex-col sm:flex-row sm:items-end gap-3 text-left">
        <div class="flex-1 w-full">
          <label for="courses-level-filter" class="block text-sm font-medium text-gray-700 mb-1">Filter by level</label>
          <select name="level" id="courses-level-filter"
            class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:outline-none"
            onchange="this.form.submit()">
            <option value="" {{ if eq .SelectedLevel "" }}selected{{ end }}>All levels</option>
            {{ range .Levels }}
              <option value="{{ . }}" {{ if eq $.SelectedLevel . }}selected{{ end }}>{{ . }}</option>
            {{ end }}
          </select>
        </div>
        <noscript>
          <button type="submit" class="inline-flex justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-blue-700">
            Apply
          </button>
        </noscript>
      </form>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {{ range .Courses }}
        <article class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 class="text-xl font-semibold text-gray-900">{{ .Name }}</h2>
              {{ if .Code }}
                <p class="text-sm text-gray-500 mt-1">{{ .Code }}</p>
              {{ end }}
            </div>
            {{ if .Level }}
              <span class="inline-flex items-center rounded-full bg-blue-100 text-blue-800 text-xs font-semibold px-3 py-1">
                {{ .Level }}
              </span>
            {{ end }}
          </div>

          {{ if .Subject }}
            <p class="mt-4 text-sm font-medium text-gray-700">Subject: {{ .Subject }}</p>
          {{ end }}

          {{ if .Description }}
            <p class="mt-3 text-gray-600 leading-relaxed">{{ .Description }}</p>
          {{ end }}
        </article>
      {{ else }}
        <div class="md:col-span-2 bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center text-gray-500">
          {{ if .SelectedLevel }}
            No courses match this level. Try another level or choose &ldquo;All levels&rdquo;.
          {{ else }}
            No active courses are available right now.
          {{ end }}
        </div>
      {{ end }}
    </div>
  </section>
</main>

{{ template "footer.tmpl" . }}
