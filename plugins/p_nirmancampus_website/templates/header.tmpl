<style>
        /* 1. CSS: Pop-up ki styling */
        .popup-overlay {
            display: none; /* Shuru mein hidden rahega */
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7); /* Peeche ka background dim karne ke liye */
            z-index: 9999; /* Sabse upar dikhane ke liye */
            justify-content: center;
            align-items: center;
        }

        .popup-content {
            position: relative;
            background-color: #fff;
            padding: 10px;
            max-width: 90%; /* Mobile friendly */
            max-height: 90%;
            border-radius: 8px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }

        .popup-content img {
            max-width: 100%;
            max-height: 80vh; /* Screen height ka 80% hi le */
            display: block;
            margin-bottom: 10px;
        }

        .close-btn {
            background-color: #ff4757;
            color: white;
            border: none;
            padding: 10px 20px;
            cursor: pointer;
            font-size: 16px;
            border-radius: 5px;
            margin-top: 10px;
        }

        .close-btn:hover {
            background-color: #e84118;
        }
    </style>
</head>
