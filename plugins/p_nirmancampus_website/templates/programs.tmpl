<section class="py-16 px-4" x-data="{ search: '' }">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-4xl font-bold text-center mb-10">Programs Offered</h1>
    <div class="mb-8 max-w-md mx-auto">
      <input
        type="text"
        x-model="search"
        placeholder="Search programs..."
        class="input input-bordered w-full"
      >
    </div>

    {{ if .Programs }}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {{ range .Programs }}
      <div
        class="card bg-base-200 shadow-md"
        x-show="!search || '{{ js .Name }} {{ js .Code }}'.toLowerCase().includes(search.toLowerCase())"
      >
        <div class="card-body">
          <h2 class="card-title">{{ .Name }}</h2>
          {{ if .Code }}<div class="badge badge-outline">{{ .Code }}</div>{{ end }}
          {{ if .Description }}<p class="mt-2">{{ .Description }}</p>{{ end }}
        </div>
      </div>
      {{ end }}
    </div>
    {{ else }}
    <p class="text-center opacity-60">No programs available at this time.</p>
    {{ end }}
  </div>
</section>

